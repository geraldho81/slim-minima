# =============================================================================
# Slim Minima - environment variables
# -----------------------------------------------------------------------------
# 1. Copy this file:            cp .env.example .env.local
# 2. Fill in the REQUIRED vars below (the OPTIONAL ones can stay blank).
# 3. Run:                       npm run db:migrate   (creates the tables)
# 4. Run:                       npm run dev
#
# Every service here is YOUR OWN free account. Slim Minima is self-hosted and
# stores nothing on our side. Each "Example:" line shows the format only - do
# not paste it, replace it with your own value.
# =============================================================================


# =============================================================================
# REQUIRED
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE_URL - your Postgres database (Neon, free tier)
# -----------------------------------------------------------------------------
# How to get it (2 minutes, free, no card):
#   1. Go to https://console.neon.tech and sign up.
#   2. Click "Create project" (any name, any region near you).
#   3. On the project dashboard, open "Connect" / "Connection string".
#   4. Choose the POOLED string (the host contains "-pooler") and copy it.
#
# Example: DATABASE_URL=postgresql://alex:npg_AbC123@ep-cool-block-12345-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=


# -----------------------------------------------------------------------------
# AUTH_SECRET - signs admin login sessions (any long random string)
# -----------------------------------------------------------------------------
# How to get it: run this in your terminal and paste the output:
#   openssl rand -base64 32
#
# Example: AUTH_SECRET=Yb6Qy7nf3kQpZc2m9XvD4rJ8sT1wL0eH5aN6uK3bP=
AUTH_SECRET=


# -----------------------------------------------------------------------------
# CLOUDINARY - stores and serves your images and files (free tier)
# -----------------------------------------------------------------------------
# How to get it (free, no card):
#   1. Go to https://cloudinary.com and sign up.
#   2. Open the Console dashboard ("Programmable Media" -> "Dashboard").
#   3. Under "Account Details" / "API Keys" copy these three values.
#
# IMPORTANT - allow PDF and ZIP files (Cloudinary blocks them by default):
#   Cloudinary Console -> Settings (gear) -> Security ->
#   "PDF and ZIP files delivery" -> tick "Allow delivery of PDF and ZIP files".
#
# You can also add these directly in the CMS: Admin -> Settings ->
# "Media storage (Cloudinary)". Set them here OR there - env vars win if both.
# Example: CLOUDINARY_CLOUD_NAME=dabcd1234
CLOUDINARY_CLOUD_NAME=
# Example: CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_KEY=
# Example: CLOUDINARY_API_SECRET=aB1cD2eF3gH4iJ5kL6mN7oP8qR9
CLOUDINARY_API_SECRET=


# =============================================================================
# OPTIONAL (safe to leave blank)
#
# Most of these can ALSO be added later, without redeploying, directly in the
# CMS: Admin -> Settings. Env vars always take precedence when set. The two
# exceptions are CRON_SECRET and NEXT_PUBLIC_SITE_URL, which must live here.
# =============================================================================

# -----------------------------------------------------------------------------
# CLOUDINARY_FOLDER - which Cloudinary folder new uploads go into.
# Leave blank to use the default "slim-minima".
# You can also add this in the CMS: Settings -> Media options.
# Example: CLOUDINARY_FOLDER=my-site-media
CLOUDINARY_FOLDER=

# -----------------------------------------------------------------------------
# MEDIA_TRASH_TTL_DAYS - days a trashed image waits before it is permanently
# deleted from Cloudinary by the daily cleanup job. Leave blank for 30.
# You can also add this in the CMS: Settings -> Media options.
# Example: MEDIA_TRASH_TTL_DAYS=30
MEDIA_TRASH_TTL_DAYS=

# -----------------------------------------------------------------------------
# RESEND - emails you contact-form submissions (free tier).
# Without it, submissions are still saved in the database and shown in the admin.
# You can also add these in the CMS: Settings -> Email notifications.
# How to get it (free): sign up at https://resend.com -> "API Keys" -> create one.
#   - EMAIL_FROM must be an address on a domain you verified in Resend, OR use
#     Resend's test sender "onboarding@resend.dev" while trying it out.
#   - EMAIL_TO is where you want submissions delivered.
#
# Example: RESEND_API_KEY=re_AbCdEf12_GhIjKlMnOpQrStUvWxYz3456
RESEND_API_KEY=
# Example: EMAIL_FROM=Slim Minima <onboarding@resend.dev>
EMAIL_FROM=
# Example: EMAIL_TO=you@yourcompany.com
EMAIL_TO=

# -----------------------------------------------------------------------------
# CRON_SECRET - protects the daily trash-cleanup endpoint in production.
# ENV ONLY (cannot be set in the CMS - it secures a deploy-time endpoint).
# Set it to any long random string (openssl rand -base64 32). On Vercel, add the
# same value in Project Settings; Vercel Cron sends it automatically.
# Example: CRON_SECRET=Zx9Wv8Ut7Sr6Qp5On4Ml3Kj2Ih1Gf0Ed=
CRON_SECRET=

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL - your public site URL, used in sitemap, RSS and social
# share tags. ENV ONLY (read at build time for SEO output). On Vercel it is
# auto-detected in production, so you can usually leave this blank.
# Example: NEXT_PUBLIC_SITE_URL=https://www.yoursite.com
NEXT_PUBLIC_SITE_URL=


# -----------------------------------------------------------------------------
# SECURITY UPDATES (optional) - the Admin -> Settings -> Security updates panel
# checks GitHub for security releases and can apply one for you.
# -----------------------------------------------------------------------------
# SLIM_MINIMA_SITE_REPO - your site's own GitHub repo as owner/name. Lets the
# Update button apply a fix by opening a pull request via GitHub Actions. On
# Vercel this is auto-detected, so you can usually leave it blank.
# Example: SLIM_MINIMA_SITE_REPO=acme/acme-website
SLIM_MINIMA_SITE_REPO=

# SLIM_MINIMA_GH_TOKEN - optional fine-grained token with "Actions: write" on
# that one repo. With it, the Update button runs the workflow automatically.
# Without it, the button just links to the workflow's "Run" page (no token
# stored in the CMS, the safer default). Keep its scope minimal.
SLIM_MINIMA_GH_TOKEN=

# SLIM_MINIMA_SITE_BRANCH - branch the update workflow runs on. Default: main.
SLIM_MINIMA_SITE_BRANCH=

# SLIM_MINIMA_UPDATE_REPO - upstream Slim Minima repo to check for releases.
# Default: geraldho81/slim-minima. Only change if you maintain your own fork.
SLIM_MINIMA_UPDATE_REPO=
